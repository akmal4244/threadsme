# ThreadsMe production/private deployment example.
# Copy to your production secret manager or server env file. Do not commit real values.

NODE_ENV=production

# Public URL and HTTPS reverse proxy.
THREADSME_PUBLIC_URL=https://threadsme.akmalmarvis.com
THREADSME_FORCE_HTTPS=true
THREADSME_HTTPS=true
THREADSME_CSP_CONNECT_SRC=https://threadsme.akmalmarvis.com

# Static UI server
THREADSME_HOST=127.0.0.1
THREADSME_PORT=8791

# API server
THREADSME_AI_HOST=127.0.0.1
THREADSME_AI_PORT=8788
THREADSME_WORKSPACE_ROOT=/var/www/threadsme
THREADSME_RUNTIME_DIR=/var/lib/threadsme/runtime
THREADSME_BACKUP_DIR=/var/backups/threadsme
THREADSME_LOG_DIR=/var/log/threadsme
THREADSME_LOG_MAX_BYTES=1048576
THREADSME_LOG_BACKUPS=7
THREADSME_BACKUP_KEEP=30

# Authentication: required for any private/internal/public deployment.
THREADSME_AUTH_REQUIRED=true
THREADSME_ADMIN_USERNAME=<admin_username>
THREADSME_ADMIN_PASSWORD=<strong_admin_password>
THREADSME_SESSION_HOURS=12

# CORS: replace with your real HTTPS domain only.
THREADSME_ALLOWED_ORIGINS=https://threadsme.akmalmarvis.com

# DeepSeek and product intelligence.
DEEPSEEK_API_KEY=<deepseek_api_key>
DEEPSEEK_API_KEY_FILE=
SHOPEE_COOKIE=
SHOPEE_COOKIE_FILE=/var/lib/threadsme/private/shopee-cookie.txt

# Threads API publisher. Keep dry-run enabled from GUI until final go-live.
THREADS_ACCESS_TOKEN=<threads_access_token>
THREADSME_PUBLISH_PREFLIGHT=true
THREADSME_PUBLISH_PREFLIGHT_AI=true

# Product Intel cache.
THREADSME_PRODUCT_INTEL_CACHE_FILE=/var/lib/threadsme/runtime/product-intel-cache.json
THREADSME_PRODUCT_INTEL_CACHE_DAYS=14
THREADSME_PRODUCT_INTEL_CACHE_MAX=500
